# ============================================================
# ASKVUTA – Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# --- Deployment ---
# URL of this backend service (Railway will provide this)
BACKEND_URL=https://your-backend.railway.app

# URL of the frontend (Vercel). Used for CORS.
# Set to "*" to allow all origins during development.
FRONTEND_URL=https://your-frontend.vercel.app

# Port to listen on. Railway sets $PORT automatically.
PORT=8000

# --- App ---
DEBUG=false

# --- Vector Store ---
# Absolute or relative path to the FAISS pickle file.
# Default is data/embeddings/vungtau_knowledge.pkl (computed from config.py).
# PKL_PATH=/app/data/embeddings/vungtau_knowledge.pkl

# --- Embedding Model ---
EMBEDDING_MODEL=paraphrase-multilingual-mpnet-base-v2

# --- LLM ---
LLM_MODEL_ID=Qwen/Qwen2.5-0.5B-Instruct
LLM_MAX_NEW_TOKENS=256
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.85

# --- Search ---
SEARCH_TOP_K=5
RAG_TOP_K=3
MAX_CHUNK_CHARS=400
